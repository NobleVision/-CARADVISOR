# ----------------------------------------------------------------------------
# GOGETTER Car Advisor — environment template
# Copy to `.env`, fill in the values, then run `pnpm db:push` + `pnpm dev`.
# On Vercel, set the same variables in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# --- REQUIRED ---------------------------------------------------------------

# Postgres connection string. Neon serverless is recommended — use the pooled
# (-pooler) host. Example:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Any long random string — signs the session cookie (incl. the admin/admin demo
# login). Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- OPTIONAL: server port (local dev only; Vercel ignores this) ------------
PORT=3000

# --- OPTIONAL: LLM (enables the AI Advisor, per-car narratives, AI personalize)
# Point these at any OpenAI-compatible chat-completions endpoint. Leave blank to
# run with deterministic, rule-based explanations instead (no errors).
#   LLM_API_URL=https://api.openai.com        (base URL; "/v1/chat/completions" is appended)
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini                       (any model your endpoint serves)
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# --- OPTIONAL: monitor cron guard -------------------------------------------
# Shared secret protecting POST /api/cron/monitor. Vercel Cron automatically
# sends `Authorization: Bearer <CRON_SECRET>` when this is set in the project.
CRON_SECRET=

# --- OPTIONAL: owner/admin marking ------------------------------------------
# Set to a user's openId (e.g. demo_admin) to auto-promote them to admin.
OWNER_OPEN_ID=
