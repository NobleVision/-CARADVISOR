# ----------------------------------------------------------------------------
# GOGETTER Car Advisor — environment template
# Copy to `.env`, fill in the values, then run `pnpm db:push` + `pnpm dev`.
# On Vercel, set the same variables in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# --- REQUIRED ---------------------------------------------------------------

# Postgres connection string. Neon serverless is recommended — use the pooled
# (-pooler) host. Example:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Any long random string — signs the session cookie (incl. the admin/admin demo
# login). Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- OPTIONAL: server port (local dev only; Vercel ignores this) ------------
PORT=3000

# --- OPTIONAL: LLM (enables the AI Advisor, per-car narratives, AI personalize)
# Point these at any OpenAI-compatible chat-completions endpoint. Leave blank to
# run with deterministic, rule-based explanations instead (no errors).
#   LLM_API_URL=https://api.openai.com        (base URL; "/v1/chat/completions" is appended)
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini                       (any model your endpoint serves)
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# --- OPTIONAL: monitor cron guard -------------------------------------------
# Shared secret protecting POST /api/cron/monitor. Vercel Cron automatically
# sends `Authorization: Bearer <CRON_SECRET>` when this is set in the project.
CRON_SECRET=

# --- OPTIONAL: owner/admin marking ------------------------------------------
# Set to a user's openId (e.g. demo_admin) to auto-promote them to admin.
OWNER_OPEN_ID=

# --- OPTIONAL: real-data cloud services --------------------------------------
# Every key below is optional; when one is missing, the matching feature falls
# back to the deterministic/seeded behavior instead of erroring.

# Z.AI (GLM) — lights up the AI Advisor, match narratives, natural-language
# search parsing, and contact drafts when the generic LLM_* vars above are
# blank. Explicit LLM_API_URL/LLM_API_KEY always take precedence (the Z.AI key
# is never sent to a custom endpoint). Default model: glm-4.5-flash (Z.AI's
# free tier — works without balance); after adding credit, set
# LLM_MODEL=glm-4.7 (cheap) or LLM_MODEL=glm-5.1 (flagship) for higher quality.
ZAI_API_KEY=

# Pinecone — semantic vehicle search + similar-vehicle matching. After setting
# the key, run `pnpm sync:pinecone` once to create/populate the index
# (gogetter-vehicles, AWS us-east-1, Pinecone-hosted embeddings).
PINECONE_API_KEY=

# Cloudinary — optimized CDN delivery for listing photos. CLOUDINARY_URL is
# the single source of truth (cloudinary://API_KEY:API_SECRET@CLOUD_NAME); the
# separate key/secret are read by the Cloudinary SDK inside the sync script.
# Run `pnpm sync:cloudinary` once to upload images + write the manifest.
CLOUDINARY_URL=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mapbox — the /map vehicle explorer + geocoding for buyer ZIPs outside the
# seeded centroid table. Use a PUBLIC (pk.) token and restrict it by URL in
# the Mapbox dashboard; it is served to the browser via config.public.
MAPBOX_TOKEN=

# Brave Search — "Live market scan" on Find My Car and "From the web" model
# intel. Metered API (small monthly credit): results are cached 6h and only
# fetched on user actions.
BRAVE_SEARCH_API_KEY=

# =============================================================================
# FUTURE / PLANNED — not read by the code yet. Uncomment + wire up when the
# matching roadmap feature lands (see README "Roadmap"). Placeholders only.
# =============================================================================

# --- Real listings feed (replaces the 102-car seeded inventory) -------------
# Marketcheck Cars API (free dev tier ~500 calls/mo) or Auto.dev Listings.
# Dealer photos in these feeds flow through the existing `pnpm sync:cloudinary`
# manifest and the Pinecone index unchanged.
# MARKETCHECK_API_KEY=
# AUTO_DEV_API_KEY=

# --- Vehicle history (premium tier — the "micro layer") ---------------------
# VinAudit resells NMVTIS title/odometer/brand data (~$0.12–$1 per report).
# Carfax/AutoCheck have no open API (dealer partnerships only).
# VINAUDIT_API_KEY=

# --- Valuation / market price ------------------------------------------------
# VinAudit Market Value API, or Marketcheck price/prediction endpoints
# (covered by MARKETCHECK_API_KEY above).
# VINAUDIT_MARKET_VALUE_KEY=

# --- Dealer reputation --------------------------------------------------------
# Google Places Details (rating + review count) / Yelp Fusion for seller
# trust signals beyond the current rule-based heuristics.
# GOOGLE_PLACES_API_KEY=
# YELP_API_KEY=

# --- Alert delivery (saved-search + price-drop notifications) ----------------
# Email via Resend; SMS via Twilio. Currently alerts are in-app only.
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Production auth (replaces the admin/admin demo login) -------------------
# AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Error monitoring ---------------------------------------------------------
# SENTRY_DSN=
